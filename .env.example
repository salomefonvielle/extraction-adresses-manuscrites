# ------------------------------------------------------------------
# Serveur VLM (plateforme PIA) — utilisé pour l'OCR et l'extraction vlm_vlm
# ------------------------------------------------------------------

# Adresse IP du serveur VLM
PIA_IP=

# Port du serveur VLM
PIA_PORT=

# Clé d'API du serveur VLM
PIA_API_KEY=

# Nom du modèle VLM (par défaut : Qwen3-VL-32B-Instruct-FP8)
PIA_MODEL="Qwen3-VL-32B-Instruct-FP8"

# ------------------------------------------------------------------
# Serveur LLM (plateforme PIA) — utilisé pour l'extraction vlm_llm et tesseract_llm
# ------------------------------------------------------------------

# URL de base du serveur LLM (compatible OpenAI)
serveur_url=

# Nom du modèle LLM
PIA_LLM_MODEL="Gpt-oss-120b"

# ------------------------------------------------------------------
# Stockage S3 — utilisé pour le pipeline vlm_vlm
# ------------------------------------------------------------------

# URL de l'endpoint S3
S3_ENDPOINT_URL=

# Identifiant d'accès AWS
AWS_ACCESS_KEY_ID=

# Clé secrète AWS
AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------------
# Proxy réseau (optionnel)
# ------------------------------------------------------------------

# Liste des hôtes à exclure du proxy, séparés par des virgules
NO_PROXY=
